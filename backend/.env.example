APP_ENV=production
AUTH_MODE=cognito
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_example
COGNITO_APP_CLIENT_ID=example-client-id
COGNITO_REQUIRED_SCOPES=

# If the API is served from a different browser origin than the frontend,
# include that frontend origin here. Same-origin single-container hosting does
# not need a production CORS origin.
CORS_ALLOW_ORIGINS=https://app.example.com,http://localhost:5173,http://localhost:3000

# Production defaults to secure cookies when APP_ENV=production.
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
FRONTEND_DIST_DIR=/app/frontend/dist
PORT=8000

# Local-only fallback identity when AUTH_MODE is disabled/local.
DEV_USER_ID=local-dev-user
